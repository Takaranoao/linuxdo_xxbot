# Telegram API 凭据(https://my.telegram.org/apps)
API_ID=
API_HASH=

# session 文件路径(相对运行目录)
SESSION_PATH=tg-cron-sender.session

# 目标 chat:@username 或数字 ID(负数表示频道/群)
TARGET_CHAT=
# 论坛 topic 根 message id(可选;非论坛留空)
TARGET_TOPIC_ID=
# 要回复的消息 id(可选;留空表示不作为回复发送)
TARGET_REPLY_TO_MSG_ID=

# 登录方式:auto | passkey | password
# - auto(默认): 先试 passkey,失败自动 fallback 到密码
# - passkey:   强制 passkey,失败报错
# - password:  跳过 passkey,直接走手机号+SMS 验证码 (+ 可选 2FA 密码)
LOGIN_METHOD=auto

# 标准 5 字段 crontab(分 时 日 月 周)
CRON=*/5 * * * *

# 要发送的消息文本
MESSAGE=hello from grammers

# Telegram 代理(可选):http / socks5 / 留空
TG_PROXY_TYPE=
TG_PROXY_HOST=127.0.0.1:7890
TG_PROXY_USERNAME=
TG_PROXY_PASSWORD=
